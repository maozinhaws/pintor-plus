# Set default behavior to automatically normalize line endings for text files
* text=auto

# Force specific file types to use LF line endings
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.svg text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.bat text eol=lf
*.cmd text eol=lf
*.sql text eol=lf
*.csv text eol=lf
*.log text eol=lf

# Binary files that should not have their line endings converted
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.jar binary
*.war binary
*.ear binary
*.bin binary
*.dat binary